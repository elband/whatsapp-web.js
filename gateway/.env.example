# Port HTTP
PORT=3000

# API key untuk REST API (header: Authorization: Bearer <API_KEY>)
API_KEY=changeme-please-set-a-strong-key

# Login dashboard & docs.
# DASHBOARD_USER kosong -> dashboard & docs publik (tanpa login). Atau set untuk mengaktifkan.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme-too
# Rahasia untuk tanda tangan cookie session. Set string acak panjang.
SESSION_SECRET=please-change-this-to-a-long-random-string
# Lama sesi cookie (jam). Default 12 jam.
SESSION_TTL_HOURS=12

# Headless browser. Set false saat mau scan via jendela Chromium langsung.
HEADLESS=true

# Webhook pesan masuk (opsional)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Throttle antar pesan keluar (anti-ban)
QUEUE_MIN_DELAY_MS=1500
QUEUE_MAX_DELAY_MS=3500

# Default session yang otomatis dibuat saat boot
DEFAULT_SESSION_ID=default
